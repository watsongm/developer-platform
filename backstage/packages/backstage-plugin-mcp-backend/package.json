{
  "name": "backstage-plugin-mcp-backend",
  "version": "0.1.0",
  "description": "Backstage backend plugin that exposes the service catalog, TechDocs, and scaffolder as MCP tools for AI coding agents.",
  "backstage": {
    "role": "backend-plugin"
  },
  "main": "./dist/index.cjs.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "backstage": "@backstage/BackendFeature",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "config.d.ts"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/watsongm/backstageMCP"
  },
  "keywords": [
    "backstage",
    "backstage-plugin",
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "catalog",
    "techdocs",
    "scaffolder"
  ],
  "scripts": {
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "^1.8.0",
    "@backstage/catalog-client": "^1.9.0",
    "@backstage/catalog-model": "^1.7.0",
    "@backstage/config": "^1.3.0",
    "@backstage/errors": "^1.2.0",
    "@backstage/plugin-permission-common": "^0.8.3",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "express": "^4.21.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@backstage/cli": "^0.27.0",
    "@types/express": "^4.17.21",
    "@types/node": "^18.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "~5.4.0"
  }
}
