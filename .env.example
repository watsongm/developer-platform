# Copy this file to .env and fill in all values before running docker compose.

# ── Organisation ──────────────────────────────────────────────────────────────
ORGANIZATION_NAME=My Organisation
GITHUB_ORG=my-github-org

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=backstage
POSTGRES_PASSWORD=change-me-in-production

# ── GitHub integration ────────────────────────────────────────────────────────
# Personal access token with repo, read:org, read:user scopes
GITHUB_TOKEN=ghp_...

# OAuth App credentials (Settings → Developer settings → OAuth Apps)
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=...

# ── Backstage backend token ───────────────────────────────────────────────────
# Used by the MCP server to authenticate against the Backstage API.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKSTAGE_TOKEN=dev-token

# ── Production only ───────────────────────────────────────────────────────────
# IDP_HOST=idp.example.com
# TECHDOCS_S3_BUCKET=my-techdocs-bucket
# AWS_REGION=eu-west-1
# AWS_ACCOUNT_ID=123456789012
